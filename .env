# PostgreSQL configs
DATABASE_PORT=5701
DATABASE_NAME=lms
DATABASE_SCHEMA=lms_schema

DATABASE_URL="jdbc:postgresql://localhost:${DATABASE_PORT}/${DATABASE_NAME}"

DATABASE_USERNAME=root
DATABASE_PASSWORD=toor

# Logto configs
LOGTO_ADMIN_PORT=3001
LOGTO_ALL_PORT=3002
LOGTO_ADMIN_ENDPOINT="http://admin.auth.localhost"
LOGTO_ENDPOINT="http://auth.localhost"

LOGTO_DB_URL="postgres://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@postgres:5432/logto"

# Nginx configs
NGINX_PORT=80
